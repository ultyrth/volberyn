PRACTICAL 12: Student Record Keeper using Dictionary and Functions
============================================================
Instruction:
Create a menu-driven student record keeper. Store name and marks using a dictionary. Allow add, search, delete, and display operations.

Code:
def add_record(records):
    name = input("Enter student name: ")
    marks = int(input(f"Enter marks for {name}: "))
    records[name] = marks
    print(f"Record added: {name} ({marks} marks)")


def search_record(records):
    name = input("Enter student name to search: ")
    if name in records:
        print(f"Found: {name} has {records[name]} marks")
    else:
        print(f"Record for {name} not found")


def delete_record(records):
    name = input("Enter student name to delete: ")
    if name in records:
        del records[name]
        print(f"Record for {name} deleted successfully")
    else:
        print(f"Record for {name} not found")


def display_records(records):
    if not records:
        print("No records available")
    else:
        print("\nCurrent Student Records:")
        for name, marks in records.items():
            print(f"Name: {name} | Marks: {marks}")


def main():
    student_records = {}

    while True:
        print("\n=== Student Record Keeper ===")
        print("1. Add Record")
        print("2. Search Record")
        print("3. Delete Record")
        print("4. Display All Records")
        print("5. Exit")

        choice = input("Enter your choice (1-5): ")

        if choice == "1":
            add_record(student_records)
        elif choice == "2":
            search_record(student_records)
        elif choice == "3":
            delete_record(student_records)
        elif choice == "4":
            display_records(student_records)
        elif choice == "5":
            print("Thank you for using student records")
            break
        else:
            print("Invalid choice! Please select between 1 and 5")


if __name__ == "__main__":
    main()

