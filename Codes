import os


def file_check_list():
    user_input = input("Enter filenames separated by space or comma: ")
    filenames = [name.strip() for name in user_input.replace(',', ' ').split() if name.strip()]

    if not filenames:
        print("No file names provided")
        return

    for filename in filenames:
        print("-" * 30)
        if os.path.isfile(filename):
            print("Full Path:", os.path.abspath(filename))
            print(filename, "exists")
        else:
            print(filename, "could not be found/opened")


if __name__ == "__main__":
    file_check_list()


